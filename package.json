{
  "name": "kitydd",
  "version": "2.0.0",
  "description": "Professional Mindmap Tool - Electron implementation of KityMinder",
  "main": "main.js",
  "author": "DDT-TDD",
  "scripts": {
    "start": "electron .",
    "dist": "npx electron-packager . KityDD --platform=win32 --arch=x64 --icon=icon.ico --overwrite",
    "build:portable": "npx electron-builder --win portable",
    "validate:release": "node scripts/validate-release.js"
  },
  "build": {
    "appId": "com.kitydd.app",
    "productName": "KityDD",
    "npmRebuild": false,
    "files": [
      "main.js",
      "local-kity-minder/**/*",
      "LICENSE",
      "THIRD_PARTY_LICENSES.md",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  }
}